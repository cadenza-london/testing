<script>
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const WEEKDAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const NUM_EMOJI = ['1️⃣','2️⃣','3️⃣','4️⃣','5️⃣','6️⃣','7️⃣','8️⃣','9️⃣'];

let students = [];
let settings = { month: 'November', year: 2025, day: 6, startTime: '08:40', endTime: '09:10' };
let parentCount = 0;

try { students = JSON.parse(localStorage.getItem('ms_students_v3') || '[]'); } catch(e) {}
try { const s = JSON.parse(localStorage.getItem('ms_settings_v3')); if(s) settings = s; } catch(e) {}

function save() { localStorage.setItem('ms_students_v3', JSON.stringify(students)); }
function saveSettings() { localStorage.setItem('ms_settings_v3', JSON.stringify(settings)); }

function init() {
  document.getElementById('gMonth').value = settings.month;
  document.getElementById('gYear').value = settings.year;
  document.getElementById('gDay').value = settings.day;
  document.getElementById('gStartTime').value = settings.startTime;
  document.getElementById('gEndTime').value = settings.endTime;
  updateUI();
}

function onSettingsChange() {
  settings.month = document.getElementById('gMonth').value;
  settings.year = parseInt(document.getElementById('gYear').value) || 2025;
  settings.day = parseInt(document.getElementById('gDay').value);
  settings.startTime = document.getElementById('gStartTime').value;
  settings.endTime = document.getElementById('gEndTime').value;
  saveSettings();
  updateUI();
}

function updateUI() {
  document.getElementById('headerMonthPill').textContent = settings.month + ' ' + settings.year;
  renderPreviewDates();
  renderStudents();
}

function getMonthDates() {
  const monthIdx = MONTHS.indexOf(settings.month);
  const dates = [];
  const d = new Date(settings.year, monthIdx, 1);
  while (d.getDay() !== settings.day) d.setDate(d.getDate() + 1);
  while (d.getMonth() === monthIdx) { dates.push(new Date(d)); d.setDate(d.getDate() + 7); }
  return dates;
}

function formatDate(d) {
  return `${d.getDate()}/${d.getMonth()+1}(${WEEKDAYS[d.getDay()]})`;
}

function renderPreviewDates() {
  const dates = getMonthDates();
  const el = document.getElementById('previewDates');
  if (!dates.length) { el.innerHTML = '<span style="color:var(--danger)">No dates found</span>'; return; }
  el.innerHTML = `<strong style="color:var(--accent)">${dates.length} ${WEEKDAYS[settings.day]}s in ${settings.month}:</strong><br>` +
    dates.map((d,i) => `${NUM_EMOJI[i]||i+1+'.'} ${formatDate(d)} ${settings.startTime}–${settings.endTime}`).join('<br>');
}

function switchTab(tab) {
  ['students','messages'].forEach(t => {
    document.getElementById('section-'+t).classList.toggle('active', t===tab);
    document.getElementById('nav-'+t).classList.toggle('active', t===tab);
  });
  document.querySelectorAll('.tab').forEach((el,i) => el.classList.toggle('active', (i===0&&tab==='students')||(i===1&&tab==='messages')));
  if (tab === 'messages') renderMessages();
}

function renderStudents() {
  document.getElementById('studentCount').textContent = students.length;
  const list = document.getElementById('studentsList');
  if (!students.length) {
    list.innerHTML = `<div class="empty-state"><div class="icon">🎵</div><p>No students yet.<br>Tap <strong>+ Add Student</strong> to begin.</p></div>`;
    return;
  }
  const dates = getMonthDates();
  list.innerHTML = students.map((s, idx) => {
    const icon = s.instrument === 'piano' ? '🎹' : '🎻';
    const dotC = s.instrument === 'piano' ? 'dot-piano' : 'dot-violin';
    const badgeC = s.instrument === 'piano' ? 'badge-piano' : 'badge-violin';
    const instrL = s.instrument === 'piano' ? 'Piano' : 'Violin';
    const st = s.startTime || settings.startTime;
    const en = s.endTime || settings.endTime;
    const total = dates.length * (s.rate || 30);
    const parentNames = (s.parents||[]).map(p=>p.name).filter(Boolean).join(' & ') || 'No parents';
    const lessonsHtml = dates.length
      ? dates.map((d,i) => `<div class="lesson-item"><span class="lesson-num-badge">${NUM_EMOJI[i]||i+1}</span><span class="lesson-date-label">${formatDate(d)}</span><span class="lesson-time-label">${st}–${en}</span></div>`).join('')
      : '<div class="no-lessons">No dates yet — check settings above</div>';
    return `<div class="student-card" id="card-${s.id}">
      <div class="card-header" onclick="toggleCard('${s.id}')">
        <div class="instrument-dot ${dotC}">${icon}</div>
        <div class="card-info">
          <div class="card-name">${s.name||'Unnamed'}</div>
          <div class="card-sub"><span class="instr-badge ${badgeC}">${instrL}</span> ${parentNames}</div>
        </div>
        <div class="card-btns">
          <button class="icon-btn" onclick="event.stopPropagation();openEditModal(${idx})">✏️</button>
          <button class="icon-btn red" onclick="event.stopPropagation();deleteStudent(${idx})">🗑</button>
          <span class="chevron">▼</span>
        </div>
      </div>
      <div class="card-body">
        <div style="margin-top:12px">
          <label class="field-label">Lessons This Month</label>
          <div class="lessons-box">${lessonsHtml}</div>
        </div>
        ${dates.length ? `<div class="total-pill"><span class="label">£${s.rate||30} × ${dates.length} lessons</span><span class="amount">Total £${total}</span></div>` : ''}
        <button class="gen-btn" onclick="goToMsg(${idx})">💬 Generate WhatsApp Message</button>
      </div>
    </div>`;
  }).join('');
}

function toggleCard(id) { document.getElementById('card-'+id).classList.toggle('expanded'); }

function deleteStudent(idx) {
  if (confirm(`Remove ${students[idx].name||'this student'}?`)) { students.splice(idx,1); save(); renderStudents(); }
}

function goToMsg(idx) {
  switchTab('messages');
  setTimeout(() => { const c = document.querySelectorAll('.msg-card'); if(c[idx]) c[idx].scrollIntoView({behavior:'smooth',block:'start'}); }, 120);
}

// MODAL
function openAddModal() {
  document.getElementById('editingId').value = '';
  document.getElementById('modalTitle').textContent = 'Add Student';
  document.getElementById('mName').value = '';
  document.getElementById('mInstrument').value = 'violin';
  document.getElementById('mRate').value = '30';
  document.getElementById('mStartTime').value = '';
  document.getElementById('mEndTime').value = '';
  document.getElementById('parentsContainer').innerHTML = '';
  parentCount = 0;
  addParentField();
  document.getElementById('modalOverlay').classList.add('open');
}

function openEditModal(idx) {
  const s = students[idx];
  document.getElementById('editingId').value = s.id;
  document.getElementById('modalTitle').textContent = 'Edit Student';
  document.getElementById('mName').value = s.name||'';
  document.getElementById('mInstrument').value = s.instrument||'violin';
  document.getElementById('mRate').value = s.rate||30;
  document.getElementById('mStartTime').value = s.startTime||'';
  document.getElementById('mEndTime').value = s.endTime||'';
  document.getElementById('parentsContainer').innerHTML = '';
  parentCount = 0;
  const parents = (s.parents && s.parents.length) ? s.parents : [{name:'',phone:''}];
  parents.forEach(p => addParentField(p.name, p.phone));
  document.getElementById('modalOverlay').classList.add('open');
}

function closeModal() { document.getElementById('modalOverlay').classList.remove('open'); }
function closeModalIfOutside(e) { if (e.target === document.getElementById('modalOverlay')) closeModal(); }

function addParentField(name='', phone='') {
  const pid = parentCount++;
  const div = document.createElement('div');
  div.className = 'parent-row';
  div.id = 'parent-'+pid;
  div.innerHTML = `<div><label class="field-label">Name</label><input type="text" id="pname-${pid}" placeholder="e.g. Judith" value="${name}"></div><div><label class="field-label">WhatsApp</label><input type="tel" id="pphone-${pid}" placeholder="+44 7700..." value="${phone}"></div>${pid>0?`<button class="remove-parent" onclick="document.getElementById('parent-${pid}').remove()">✕</button>`:''}`;
  document.getElementById('parentsContainer').appendChild(div);
}

function saveStudent() {
  const name = document.getElementById('mName').value.trim();
  if (!name) { showToast('Please enter a student name'); return; }
  const parents = [];
  document.querySelectorAll('#parentsContainer .parent-row').forEach(row => {
    const pid = row.id.replace('parent-','');
    const pn = (document.getElementById('pname-'+pid)?.value||'').trim();
    const pp = (document.getElementById('pphone-'+pid)?.value||'').trim();
    if (pn||pp) parents.push({name:pn,phone:pp});
  });
  const eid = document.getElementById('editingId').value;
  const data = { id: eid||Date.now().toString(), name, instrument: document.getElementById('mInstrument').value, rate: parseFloat(document.getElementById('mRate').value)||30, startTime: document.getElementById('mStartTime').value||'', endTime: document.getElementById('mEndTime').value||'', parents };
  if (eid) { const i = students.findIndex(s=>s.id===eid); if(i>=0) students[i]=data; } else students.push(data);
  save(); closeModal(); renderStudents();
  showToast(eid ? 'Student updated! ✅' : 'Student added! ✅');
}

// MESSAGES
function generateMessage(s) {
  const dates = getMonthDates();
  const st = s.startTime || settings.startTime;
  const en = s.endTime || settings.endTime;
  const rate = s.rate || 30;
  const total = dates.length * rate;
  const lastDate = dates.length ? dates[dates.length-1] : null;
  const lastStr = lastDate ? formatDate(lastDate) : '?';
  const parentNames = (s.parents||[]).map(p=>p.name).filter(Boolean);
  const greeting = parentNames.length ? parentNames.join(' and ') : 'there';
  const scheduleLines = dates.map((d,i) => `${NUM_EMOJI[i]||i+1+'.'}${formatDate(d)} ${st}-${en}`).join('\n');
  return `Hello ${greeting}, hope you are doing well! \n⭐️I am writing to confirm the ${settings.year} ${settings.month} schedule as below:\n\n${s.name}\n${scheduleLines}\n\nTherefore the tuition for ${settings.month} will be:\n£${rate} x ${dates.length} lessons = Total £${total}\n\nWarm reminder that please bring along with cash £${total} before ${lastStr}(Last lesson of the month)🙏🏻Thank you so much! See you soon! 😄`;
}

function renderMessages() {
  const list = document.getElementById('messagesList');
  if (!students.length) {
    list.innerHTML = `<div class="empty-state"><div class="icon">💬</div><p>Add students first,<br>then messages appear here.</p></div>`;
    return;
  }
  list.innerHTML = students.map((s,idx) => {
    const msg = generateMessage(s);
    const icon = s.instrument==='piano'?'🎹':'🎻';
    const dotC = s.instrument==='piano'?'dot-piano':'dot-violin';
    const badgeC = s.instrument==='piano'?'badge-piano':'badge-violin';
    const instrL = s.instrument==='piano'?'Piano':'Violin';
    const parentWithPhone = (s.parents||[]).find(p=>p.phone);
    const phone = parentWithPhone ? parentWithPhone.phone.replace(/\s+/g,'').replace(/^\+/,'') : null;
    const waLink = phone ? `https://wa.me/${phone}?text=${encodeURIComponent(msg)}` : null;
    return `<div class="msg-card">
      <div class="msg-card-header">
        <div class="instrument-dot ${dotC}">${icon}</div>
        <div class="card-info">
          <div class="msg-name">${s.name||'Unnamed'}</div>
          <div class="msg-sub"><span class="instr-badge ${badgeC}">${instrL}</span> · ${(s.parents||[]).map(p=>p.name).filter(Boolean).join(' & ')||'No parents'}</div>
        </div>
      </div>
      <div class="msg-body">${escHtml(msg)}</div>
      <div class="msg-actions">
        <button class="copy-btn" onclick="copyMsg(${idx})">📋 Copy</button>
        ${waLink ? `<a class="wa-btn" href="${waLink}" target="_blank">🟢 Open in WhatsApp</a>` : `<div class="wa-btn disabled">Add phone first</div>`}
      </div>
    </div>`;
  }).join('');
}

function copyMsg(idx) {
  const msg = generateMessage(students[idx]);
  if (navigator.clipboard) { navigator.clipboard.writeText(msg).then(()=>showToast('Copied! 📋')); }
  else { const ta=document.createElement('textarea'); ta.value=msg; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); showToast('Copied! 📋'); }
}

function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2200);
}

init();
</script>

