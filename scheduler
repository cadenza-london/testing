<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Music Scheduler</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #fdf8ee;
  --surface: #fffdf5;
  --card: #faf3e0;
  --accent: #b5893a;
  --accent2: #c9a84c;
  --gold: #d4a843;
  --soft: #fef3d0;
  --danger: #c0392b;
  --text: #2e2210;
  --muted: #9a8866;
  --border: #e8d9b0;
  --radius: 16px;
  --piano: #5a4a8a;
  --violin: #8a3a2a;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { background: var(--bg); color: var(--text); font-family: 'Lato', sans-serif; min-height: 100vh; padding-bottom: 80px; }
header { background: linear-gradient(135deg, #c9973a 0%, #e8c46a 50%, #c9973a 100%); padding: 18px 20px 14px; position: sticky; top: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; gap: 10px; box-shadow: 0 2px 12px rgba(180,130,40,0.25); }
.app-title { font-family: 'Playfair Display', serif; font-size: 23px; color: #3a2200; white-space: nowrap; font-style: italic; letter-spacing: 0.2px; text-shadow: 0 1px 2px rgba(255,255,255,0.3); }
.app-title span { color: #6b3a00; font-style: normal; }
.month-pill { background: rgba(60,30,0,0.15); border: 1px solid rgba(60,30,0,0.2); border-radius: 20px; padding: 6px 12px; font-size: 12px; font-weight: 700; color: #3a2200; white-space: nowrap; }
main { padding: 14px 14px 0; max-width: 480px; margin: 0 auto; }
.tabs { display: flex; background: var(--card); border-radius: 12px; padding: 3px; margin-bottom: 16px; border: 1px solid var(--border); }
.tab { flex: 1; text-align: center; padding: 10px 6px; border-radius: 10px; font-size: 13px; font-weight: 700; cursor: pointer; color: var(--muted); transition: all 0.2s; user-select: none; font-family: 'Lato', sans-serif; }
.tab.active { background: linear-gradient(135deg, #c9973a, #e8c46a); color: #3a2200; }
.section { display: none; }
.section.active { display: block; }
.setup-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-bottom: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.setup-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.9px; color: var(--muted); margin-bottom: 12px; }
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
label.field-label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: var(--muted); margin-bottom: 5px; }
select, input[type=text], input[type=tel], input[type=number], input[type=date], input[type=time] { width: 100%; background: var(--card); border: 1px solid var(--border); border-radius: 10px; color: var(--text); font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 500; padding: 9px 11px; outline: none; transition: border-color 0.2s; -webkit-appearance: none; appearance: none; }
select:focus, input:focus { border-color: var(--accent2); }
.gen-btn { width: 100%; background: linear-gradient(135deg, #c9973a, #e8c46a); color: #3a2200; border: none; border-radius: 11px; padding: 12px; font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; margin-top: 12px; transition: opacity 0.15s; box-shadow: 0 2px 8px rgba(180,130,40,0.2); }
.gen-btn:active { opacity: 0.85; }
.students-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.section-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); }
.add-btn { background: linear-gradient(135deg, #c9973a, #e8c46a); color: #3a2200; border: none; border-radius: 20px; padding: 7px 15px; font-size: 12px; font-weight: 700; cursor: pointer; font-family: 'Lato', sans-serif; box-shadow: 0 1px 6px rgba(180,130,40,0.2); }
.student-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 10px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.05); transition: border-color 0.2s; }
.student-card.expanded { border-color: var(--accent2); }
.card-header { display: flex; align-items: center; padding: 12px 14px; cursor: pointer; gap: 10px; }
.instrument-dot { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.dot-violin { background: #fce8e8; }
.dot-piano { background: #e8ecfc; }
.card-info { flex: 1; min-width: 0; }
.card-name { font-size: 15px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-sub { font-size: 11px; color: var(--muted); margin-top: 2px; display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.instr-badge { border-radius: 5px; padding: 1px 6px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; }
.badge-violin { background: #fce8e8; color: var(--violin); }
.badge-piano { background: #e8ecfc; color: var(--piano); }
.card-btns { display: flex; gap: 6px; align-items: center; }
.icon-btn { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 5px 9px; font-size: 13px; cursor: pointer; color: var(--muted); }
.icon-btn.red { color: var(--danger); }
.chevron { font-size: 10px; color: var(--muted); transition: transform 0.2s; }
.student-card.expanded .chevron { transform: rotate(180deg); }
.card-body { display: none; padding: 0 14px 14px; border-top: 1px solid var(--border); }
.student-card.expanded .card-body { display: block; }
.field-group { margin-top: 12px; }
.lessons-box { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 10px; margin-top: 6px; }
.lesson-item { display: flex; align-items: center; gap: 8px; padding: 7px 8px; background: var(--surface); border: 1px solid var(--border); border-radius: 9px; margin-bottom: 6px; }
.lesson-item:last-child { margin-bottom: 0; }
.lesson-num-badge { font-size: 14px; flex-shrink: 0; }
.lesson-date-label { flex: 1; font-size: 13px; font-weight: 500; }
.lesson-time-label { font-size: 12px; color: var(--muted); }
.no-lessons { text-align: center; font-size: 12px; color: var(--muted); padding: 8px 0; }
.total-pill { display: flex; align-items: center; justify-content: space-between; background: var(--soft); border: 1px solid #c8ddb8; border-radius: 10px; padding: 8px 12px; margin-top: 10px; }
.total-pill .label { font-size: 12px; color: var(--accent); font-weight: 500; }
.total-pill .amount { font-size: 16px; font-weight: 700; color: var(--accent); font-family: 'Cormorant Garamond', serif; }
.msg-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
.msg-card-header { padding: 12px 14px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); }
.msg-name { font-size: 15px; font-weight: 600; }
.msg-sub { font-size: 11px; color: var(--muted); margin-top: 1px; }
.msg-body { padding: 14px; font-size: 13.5px; line-height: 1.7; white-space: pre-wrap; background: var(--card); font-family: -apple-system, sans-serif; color: var(--text); border-bottom: 1px solid var(--border); }
.msg-actions { display: flex; gap: 8px; padding: 10px 14px; }
.copy-btn { flex: 1; background: var(--card); border: 1px solid var(--border); color: var(--text); font-family: 'Lato', sans-serif; font-size: 13px; font-weight: 700; padding: 10px; border-radius: 10px; cursor: pointer; }
.wa-btn { flex: 1.5; background: #25d366; border: none; color: #fff; font-family: 'Lato', sans-serif; font-size: 13px; font-weight: 700; padding: 10px; border-radius: 10px; cursor: pointer; text-decoration: none; text-align: center; display: flex; align-items: center; justify-content: center; gap: 5px; }
.wa-btn.disabled { background: #b0b0b0; cursor: default; pointer-events: none; }
.empty-state { text-align: center; padding: 50px 20px; color: var(--muted); }
.empty-state .icon { font-size: 44px; margin-bottom: 14px; }
.empty-state p { font-size: 14px; line-height: 1.6; }
.toast { position: fixed; bottom: 92px; left: 50%; transform: translateX(-50%) translateY(16px); background: var(--accent); color: #fff; padding: 10px 22px; border-radius: 20px; font-size: 13px; font-weight: 600; opacity: 0; transition: all 0.25s; pointer-events: none; z-index: 999; white-space: nowrap; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
.bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--surface); border-top: 1px solid var(--border); display: flex; z-index: 200; padding-bottom: env(safe-area-inset-bottom, 0); }
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px; cursor: pointer; padding: 8px 0; color: var(--muted); font-size: 11px; font-weight: 700; font-family: 'Lato', sans-serif; }
.nav-item.active { color: var(--accent); }
.nav-icon { font-size: 20px; }
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 500; align-items: flex-end; justify-content: center; }
.modal-overlay.open { display: flex; }
.modal { background: var(--surface); border-radius: 20px 20px 0 0; padding: 20px; width: 100%; max-width: 480px; max-height: 90vh; overflow-y: auto; animation: slideUp 0.25s ease; }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.modal-handle { width: 40px; height: 4px; background: var(--border); border-radius: 2px; margin: 0 auto 18px; }
.modal-title { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; margin-bottom: 16px; color: var(--accent); font-style: italic; }
.modal-footer { display: flex; gap: 8px; margin-top: 16px; }
.btn-cancel { flex: 1; background: var(--card); border: 1px solid var(--border); color: var(--text); font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 600; padding: 12px; border-radius: 11px; cursor: pointer; }
.btn-save { flex: 2; background: linear-gradient(135deg, #c9973a, #e8c46a); border: none; color: #3a2200; font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 700; padding: 12px; border-radius: 11px; cursor: pointer; }
.parent-row { display: flex; gap: 8px; align-items: flex-end; margin-bottom: 8px; }
.parent-row > div { flex: 1; }
.remove-parent { background: none; border: 1px solid var(--border); border-radius: 8px; color: var(--danger); font-size: 14px; padding: 8px 9px; cursor: pointer; flex-shrink: 0; height: 38px; }
.add-parent-btn { background: transparent; border: 1px dashed var(--border); border-radius: 9px; color: var(--muted); font-family: 'Lato', sans-serif; font-size: 12px; font-weight: 500; padding: 7px; cursor: pointer; width: 100%; margin-top: 2px; }
.hint { font-size: 11px; color: var(--muted); margin-top: 4px; }
#previewDates { margin-top: 10px; font-size: 12px; color: var(--muted); line-height: 1.8; }
</style>
</head>
